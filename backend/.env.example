PORT=5000
NODE_ENV=production

# Public site URL used for tracking links and GeniusPay return URLs
FRONTEND_URL=https://soratech.ci

# GeniusPay API
GENIUSPAY_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GENIUSPAY_API_SECRET=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Create this webhook in GeniusPay dashboard:
# https://your-backend-domain/api/commandes/webhooks/geniuspay
GENIUSPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional override if GeniusPay changes their base URL
# GENIUSPAY_BASE_URL=https://pay.genius.ci/api/v1/merchant
